generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String     @id @default(cuid())
  email                    String     @unique
  password                 String?
  name                     String?
  displayName              String?    // public leaderboard name
  showOnLeaderboard        Boolean    @default(true)
  plan                     String     @default("free")
  bonusCredits             Int        @default(0)
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String?
  emailDigest              Boolean    @default(true)
  referralCode             String?    @unique
  referredBy               String?    // referral code of the user who referred them
  createdAt                DateTime   @default(now())
  analyses                 Analysis[]
  packPurchases            PackPurchase[]
  priceAlerts              PriceAlert[]
}

model DiscountCode {
  id          String   @id @default(cuid())
  code        String   @unique
  plan        String
  usesLeft    Int?
  usesTotal   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  redemptions CodeRedemption[]
}

model CodeRedemption {
  id         String       @id @default(cuid())
  userId     String
  codeId     String
  code       DiscountCode @relation(fields: [codeId], references: [id])
  redeemedAt DateTime     @default(now())
}

model PackPurchase {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  packId      String   // "pack_10" | "pack_30" | "pack_100"
  credits     Int
  amountPaid  Int      // in cents
  stripeSessionId String?
  createdAt   DateTime @default(now())
}


model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  ticker      String
  condition   String
  targetPrice Float
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model ChatMessage {
  id         String   @id @default(cuid())
  userId     String
  analysisId String
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now())
}

model Analysis {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  imageUrl       String
  recommendation String
  confidence     Int
  reasoning      String
  marketType     String
  signals        String
  usedCredit     Boolean  @default(false)
  starred        Boolean  @default(false)
  // Accuracy tracking
  tickerSymbol   String?  // e.g. "BTC", "NVDA" — set at scan time if provided
  priceAtScan    Float?   // price when scan was created
  price24hLater  Float?   // price fetched ~24h after scan
  autoCorrect    Boolean? // null = pending, true = correct, false = incorrect
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
}
